{
  "name": "kriniks-tools",
  "version": "1.0.0",
  "description": "KrinikCam build & release automation tools",
  "type": "module",
  "scripts": {
    "setup": "node setup.mjs",
    "build": "node build.mjs",
    "build:release": "node build.mjs --release",
    "build:ci": "node build.mjs --no-ui",
    "commit": "node commit.mjs",
    "release": "node release.mjs",
    "release:major": "node release.mjs --major",
    "release:dry": "node release.mjs --dry-run",
    "readme-pdf": "node readme-pdf.mjs",
    "draw": "node graphics/render.mjs",
    "draw:batch": "node graphics/batch.mjs",
    "kaif:version": "cd .. && node .kaif/kaif-core.mjs version",
    "kaif:check": "cd .. && node .kaif/kaif-core.mjs check",
    "kaif:update": "cd .. && node .kaif/kaif-core.mjs update",
    "kaif:fork": "node kaif.mjs fork",
    "kaif:switch-origin": "node kaif.mjs switch-origin",
    "kaif:remove": "node kaif.mjs remove",
    "kaif:remove-all": "node kaif.mjs remove-all"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "md-to-pdf": "^5.2.4",
    "sharp": "^0.35.2"
  }
}
