<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access required for RTMP/RTSP streaming -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Audio capture from USB microphone or internal mic -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Foreground service keeps streaming alive when app is backgrounded -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />

    <!-- Required for Android 13+ notification permission (stream status notification) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Camera — required by Android 14+ UsbUserPermissionManager for UVC (USB video class) devices -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- USB host mode — connect external webcams via OTG -->
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <!-- Internal camera is optional — USB webcam is the primary source -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".KrinikCamApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KrinikCam"
        android:largeHeap="true">

        <!-- FileProvider — exposes log files via content:// URI for the share intent.
             Authority must match the string used in FileLogger.shareIntent(). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!-- Main activity — single-activity architecture with Compose NavHost -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:screenOrientation="fullSensor"
            android:windowSoftInputMode="adjustResize"
            android:launchMode="singleTask"><!--
                Bug 09 (fix #2): without singleTask, the USB_DEVICE_ATTACHED intent-filter spawns a
                NEW MainActivity instance on every camera attach (default launchMode = standard).
                Each instance re-started USB monitoring → re-enumerated → re-requested permission,
                cascading into dozens of stacked permission dialogs. singleTask keeps ONE instance;
                the attach intent is delivered to it via onNewIntent instead of stacking. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- USB device attach (Bug 09): registering this filter makes Android show the
                 "Use by default for this USB device" checkbox in the permission dialog and,
                 once ticked, AUTO-GRANTS access on every future attach without re-prompting.
                 This is what stops the "Grant camera access" dialog reappearing on hot replug.
                 device_filter matches UVC webcams (Misc/IAD composite, class 239/2). -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>

    </application>

</manifest>
